# ═══════════════════════════════════════════════════════════════════════════
# Client Intelligence Hub — environment template
# Copy to .env and fill in. Anything marked [REQUIRED] must be set to boot/sync.
#
# IMPORTANT: provider tokens (ClickUp access token, GHL token, Google refresh
# tokens) do NOT go in this file. They live AES-encrypted in the `connections`
# table in Supabase. This file only holds infrastructure + OAuth *app* creds.
# ═══════════════════════════════════════════════════════════════════════════

# ── Supabase (your new dedicated project) ──────────────────────────────────
# Supabase dashboard → Project Settings → Data API → "Project URL"
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co                # [REQUIRED]

# Supabase dashboard → Project Settings → API Keys → "service_role" (secret!)
# This bypasses row-level security — the hub is the trusted service layer.
# Never expose it to a browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                          # [REQUIRED]

# ── Hub identity ────────────────────────────────────────────────────────────
# After running db/schema.sql, create your tenant and paste its id here:
#   insert into tenants (name) values ('Map Ranking') returning id;
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000           # [REQUIRED]

# ── Server & security ───────────────────────────────────────────────────────
# Port the hub listens on
MCP_PORT=3001

# Bearer secret apps/agents send as: Authorization: Bearer <value>
# Generate:  openssl rand -hex 32
MCP_SECRET=                                                      # [REQUIRED]

# 32-byte hex key used to AES-256-GCM encrypt provider credentials at rest.
# Generate:  openssl rand -hex 32
# WARNING: if you lose or change this, stored connection credentials become
# unreadable and every provider must be reconnected. Back it up securely.
TENANT_ENCRYPTION_KEY=                                           # [REQUIRED]

# ── Scheduler (optional) ────────────────────────────────────────────────────
# How often the scheduler checks for due syncs, in seconds (default 60)
#SCHEDULER_TICK_SECONDS=60
# Set true to run the MCP API without any background syncing (useful in dev)
#SYNC_DISABLED=true

# ── Google OAuth app (one app covers GSC, GA4, GBP, Ads, Gmail, Drive, ...) ─
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (type: Web application). Needed by every google-* connector to refresh
# access tokens from the stored refresh_token.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com             # [REQUIRED for google-* connectors]
GOOGLE_CLIENT_SECRET=GOCSPX-...                                  # [REQUIRED for google-* connectors]
# Redirect URI registered on that OAuth client — used only during the consent
# flow that produces the refresh_token you store in `connections`.
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth/google/callback

# ── ClickUp OAuth app (optional — only for running the OAuth consent flow) ──
# ClickUp → Settings → Apps → Create app. The resulting access_token is what
# gets stored (encrypted) in the connections table.
#CLICKUP_CLIENT_ID=
#CLICKUP_CLIENT_SECRET=

# ── Google Ads (only when the google-ads connector is implemented) ─────────
#GOOGLE_ADS_DEVELOPER_TOKEN=
#GOOGLE_ADS_MCC_ID=
